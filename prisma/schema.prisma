generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  company   String?
  service   String?
  message   String
  createdAt DateTime @default(now())
}

model JobApplication {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  position  String?
  message   String?
  createdAt DateTime @default(now())
}
